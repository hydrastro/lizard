(define (fact n) (if (= n 0) 1 (* n (fact (- n 1)))))
(display "100! = ") (display (fact 100)) (newline)
(display "2^256 = ") (display (expt 2 256)) (newline)
(display "gcd(48,36) = ") (display (gcd 48 36)) (newline)
(display "lcm(48,36) = ") (display (lcm 48 36)) (newline)
(display "(expt 7 100) mod 1000 = ") (display (modular-expt 7 100 1000)) (newline)
(display "shift 1 << 64 = ") (display (arithmetic-shift 1 64)) (newline)
(display "square 99 = ") (display (square 99)) (newline)
(display "abs -123 = ") (display (abs -123)) (newline)
